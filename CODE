#include <stdio.h>
#include <string.h>

struct Library
{
    int book_id;
    char book_name[50];
    char author[50];
    int quantity;
};

struct Library lib[100];
int count = 0;

// Function to add books
void addBook()
{
    printf("\nEnter Book ID: ");
    scanf("%d", &lib[count].book_id);

    printf("Enter Book Name: ");
    scanf(" %[^\n]", lib[count].book_name);

    printf("Enter Author Name: ");
    scanf(" %[^\n]", lib[count].author);

    printf("Enter Quantity: ");
    scanf("%d", &lib[count].quantity);

    count++;

    printf("\nBook Added Successfully!\n");
}

// Function to display books
void displayBooks()
{
    int i;

    if(count == 0)
    {
        printf("\nNo Books Available!\n");
        return;
    }

    printf("\n===== Library Books =====\n");

    for(i = 0; i < count; i++)
    {
        printf("\nBook ID : %d", lib[i].book_id);
        printf("\nBook Name : %s", lib[i].book_name);
        printf("\nAuthor : %s", lib[i].author);
        printf("\nQuantity : %d\n", lib[i].quantity);
    }
}

// Function to search book
void searchBook()
{
    char name[50];
    int i, found = 0;

    printf("\nEnter Book Name to Search: ");
    scanf(" %[^\n]", name);

    for(i = 0; i < count; i++)
    {
        if(strcmp(lib[i].book_name, name) == 0)
        {
            printf("\nBook Found!\n");
            printf("Book ID : %d\n", lib[i].book_id);
            printf("Author : %s\n", lib[i].author);
            printf("Quantity : %d\n", lib[i].quantity);

            found = 1;
            break;
        }
    }

    if(found == 0)
    {
        printf("\nBook Not Found!\n");
    }
}

// Function to issue book
void issueBook()
{
    int id, i, found = 0;

    printf("\nEnter Book ID to Issue: ");
    scanf("%d", &id);

    for(i = 0; i < count; i++)
    {
        if(lib[i].book_id == id)
        {
            found = 1;

            if(lib[i].quantity > 0)
            {
                lib[i].quantity--;
                printf("\nBook Issued Successfully!\n");
            }
            else
            {
                printf("\nBook Not Available!\n");
            }

            break;
        }
    }

    if(found == 0)
    {
        printf("\nInvalid Book ID!\n");
    }
}

int main()
{
    int choice;

    while(1)
    {
        printf("\n===== Library Management System =====\n");
        printf("1. Add Book\n");
        printf("2. Display Books\n");
        printf("3. Search Book\n");
        printf("4. Issue Book\n");
        printf("5. Exit\n");

        printf("Enter Your Choice: ");
        scanf("%d", &choice);

        switch(choice)
        {
            case 1:
                addBook();
                break;

            case 2:
                displayBooks();
                break;

            case 3:
                searchBook();
                break;

            case 4:
                issueBook();
                break;

            case 5:
                printf("\nThank You!\n");
                return 0;

            default:
                printf("\nInvalid Choice!\n");
        }
    }

    return 0;
}
